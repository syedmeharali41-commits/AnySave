{
  "name": "anysave",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "loader.js",
  "author": "Syed Mehar Ali",
  "description": "AnySave Advanced Video Downloader Tool",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "npm start",
    "electron:build": "npm run dist",
    "compile-bytecode": "electron ./build-bytecode.js",
    "start": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on http://localhost:5173 -t 30000 && electron .\"",
    "dist": "vite build && npm run compile-bytecode && electron-builder"
  },
  "build": {
    "appId": "com.syedmeharali.anysave",
    "productName": "AnySave",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "loader.js",
      "main.js",
      "main.jsc",
      "preload.js",
      "public/**/*",
      "package.json",
      "logo.ico"
    ],
    "extraFiles": [
      {
        "from": "bin",
        "to": "resources/bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AnySave",
      "artifactName": "${productName} Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "bytenode": "^1.5.7",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "electron-updater": "^6.1.7",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.10",
    "wait-on": "^8.0.1"
  }
}